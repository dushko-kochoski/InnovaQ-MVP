# ── InnovaQ environment variables ──────────────────────────────────────
# Copy to .env for local development. On Railway, set these in the
# service's Variables tab instead (no .env file is deployed).

# Database connection string.
#   Local dev:  sqlite:///./innovaq.db
#   Railway:    ${{Postgres.DATABASE_URL}}  (reference the Postgres plugin;
#               postgres:// URLs are normalized to postgresql:// automatically)
DATABASE_URL=sqlite:///./innovaq.db

# JWT signing key. Generate a long random string, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=generate-a-long-random-string

# The origin the frontend is served from — used for CORS and must match
# exactly (scheme + host, no trailing slash).
#   Local dev:  http://127.0.0.1:3000
#   Production: https://your-site.netlify.app
FRONTEND_URL=http://127.0.0.1:3000

# true  → dev mode: relaxed cookies (SameSite=Lax, not Secure), extra CORS
#         origins for localhost, debug logging.
# false → production: Secure SameSite=None cookies (required for the
#         cross-site Netlify→Railway setup), CORS locked to FRONTEND_URL.
DEBUG=false
